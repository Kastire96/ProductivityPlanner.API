<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProductivityPlanner.Mobile.MainPage"
             BackgroundColor="#F3F4F6">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="30" VerticalOptions="Center">
            <Label Text="Productivity Planner" FontSize="32" FontAttributes="Bold" TextColor="#1F2937" HorizontalOptions="Center" />
            <Label Text="Zaloguj się do swojego konta" FontSize="16" TextColor="#4B5563" HorizontalOptions="Center" Margin="0,0,0,20" />

            <Border StrokeThickness="1" Stroke="#E5E7EB" Padding="20" BackgroundColor="White">
                <VerticalStackLayout Spacing="15">
                    <Entry x:Name="EmailEntry" Placeholder="Adres e-mail" Keyboard="Email" TextColor="#1F2937" PlaceholderColor="#9CA3AF" />
                    <Entry x:Name="PasswordEntry" Placeholder="Hasło" IsPassword="True" TextColor="#1F2937" PlaceholderColor="#9CA3AF" />
                </VerticalStackLayout>
            </Border>

            <Button Text="Zaloguj się" Clicked="OnLoginClicked" BackgroundColor="#2563EB" TextColor="White" FontAttributes="Bold" HeightRequest="50" />
            <Label x:Name="ErrorLabel" TextColor="#EF4444" HorizontalOptions="Center" IsVisible="False" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>