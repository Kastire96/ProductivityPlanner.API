<Window x:Class="ProductivityPlanner.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Planer Produktywności - Logowanie" Height="350" Width="400" 
        WindowStartupLocation="CenterScreen" Background="#F3F4F6">
    <Grid Margin="30">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Zaloguj się" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center" Foreground="#1F2937"/>

            <TextBlock Text="Email:" Margin="0,5,0,2" Foreground="#4B5563"/>
            <TextBox x:Name="TxtEmail" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,10"/>

            <TextBlock Text="Hasło:" Margin="0,5,0,2" Foreground="#4B5563"/>
            <PasswordBox x:Name="TxtPassword" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,20"/>

            <Button x:Name="BtnLogin" Content="Zaloguj" Height="35" Background="#2563EB" Foreground="White" FontWeight="Bold" Click="BtnLogin_Click"/>

            <TextBlock x:Name="LblError" Foreground="Red" HorizontalAlignment="Center" Margin="0,5,0,5" Visibility="Collapsed"/>
        </StackPanel>
    </Grid>
</Window>