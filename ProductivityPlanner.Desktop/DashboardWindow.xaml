<Window x:Class="ProductivityPlanner.Desktop.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Panel Zadania" Height="500" Width="800" 
        WindowStartupLocation="CenterScreen" Background="#F9FAFB" Loaded="Window_Loaded">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Moje Zadania" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0"/>
            <TextBox x:Name="TxtSearch" Width="200" Height="25" VerticalContentAlignment="Center" Margin="0,0,10,0" ToolTip="Wyszukaj po tytule..."/>
            <Button Content="Szukaj" Width="70" Click="BtnSearch_Click" Background="#4B5563" Foreground="White"/>
        </StackPanel>

        <Border Grid.Row="1" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" Padding="10" CornerRadius="5" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="Tytuł zadania:" FontSize="11" Foreground="#6B7280"/>
                    <TextBox x:Name="TxtNewTitle" Width="150" Height="25"/>
                </StackPanel>
                <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="Kategoria:" FontSize="11" Foreground="#6B7280"/>
                    <TextBox x:Name="TxtNewCategory" Width="100" Height="25" Text="Ogólne"/>
                </StackPanel>
                <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="Priorytet:" FontSize="11" Foreground="#6B7280"/>
                    <ComboBox x:Name="CmbNewPriority" Width="100" Height="25" SelectedIndex="1">
                        <ComboBoxItem Content="Niski"/>
                        <ComboBoxItem Content="Średni"/>
                        <ComboBoxItem Content="Wysoki"/>
                    </ComboBox>
                </StackPanel>
                <Button Content="Dodaj nowe" Width="100" Height="25" Margin="10,13,0,0" Click="BtnAddTask_Click" Background="#10B981" Foreground="White" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <DataGrid x:Name="GridTasks" Grid.Row="2" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Single" BorderThickness="1" BorderBrush="#E5E7EB">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="40" IsReadOnly="True"/>
                <DataGridTextColumn Header="Tytuł" Binding="{Binding Title}" Width="*"/>
                <DataGridTextColumn Header="Kategoria" Binding="{Binding Category}" Width="100"/>
                <DataGridTextColumn Header="Priorytet" Binding="{Binding Priority}" Width="80"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                <DataGridTemplateColumn Header="Akcje" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Zakończ" Click="BtnComplete_Click" Background="#3B82F6" Foreground="White" Padding="5,2" Margin="2"/>
                                <Button Content="Usuń" Click="BtnDelete_Click" Background="#EF4444" Foreground="White" Padding="5,2" Margin="2"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Generuj Raport CSV" Width="150" Height="30" Click="BtnExportCsv_Click" Background="#F59E0B" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>